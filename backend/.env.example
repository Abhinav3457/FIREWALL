APP_NAME=CAFW API
APP_ENV=dev
SECRET_KEY=replace-with-strong-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

MONGODB_URL=mongodb+srv://<db_user>:<db_password>@<cluster-host>/cafw?retryWrites=true&w=majority
MONGODB_DB_NAME=cafw
REDIS_URL=rediss://default:<redis_password>@<redis-host>:6379

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-strong-password

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=replace-with-gmail-app-password
SMTP_FROM=your-email@gmail.com
SMTP_ENABLED=false
