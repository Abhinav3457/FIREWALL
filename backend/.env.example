APP_NAME=CAFW API
APP_ENV=development
SECRET_KEY=replace_with_long_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

DATABASE_URL=postgresql+psycopg://postgres:your_password@localhost:5432/cafw_db
REDIS_URL=redis://localhost:6379/0
FRONTEND_ORIGIN=http://localhost:5173

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=$2b$12$replace_with_bcrypt_hash
ADMIN_PASSWORD=

OTP_EXPIRE_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_LOCK_SECONDS=30

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
EMAIL_FROM=your_email@gmail.com

WAF_BLOCK_PATTERNS=../,<script,union select,drop table,or 1=1